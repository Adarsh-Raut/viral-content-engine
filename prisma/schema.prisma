generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id         String   @id @default(cuid())
  source     String
  externalId String   @unique
  title      String
  mediaUrl   String
  postUrl    String
  upvotes    Int
  comments   Int
  score      Float
  createdAt  DateTime
  fetchedAt  DateTime @default(now())
}
